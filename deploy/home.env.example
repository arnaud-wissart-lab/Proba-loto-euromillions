# Copier ce fichier vers deploy/home.env puis adapter toutes les valeurs.
# Ne jamais commiter deploy/home.env (contient des secrets machine).

# Base de donnees
POSTGRES_USER=probaloto
POSTGRES_PASSWORD=change-me-strong-db-password

# Admin
ADMIN_API_KEY=change-me-strong-admin-api-key
ADMIN_WEB_USERNAME=admin
ADMIN_WEB_PASSWORD=change-me-strong-admin-password

# Legacy (compatibilite endpoints /api/subscriptions)
PUBLIC_BASE_URL=https://loto.arnaudwissart.fr
SUBSCRIPTIONS_TOKEN_SECRET=change-me-very-long-random-secret

# Optionnel: check SMTP dans /health/ready
HEALTHCHECKS_SMTP_ENABLED=true

# Optionnel: origine CORS supplementaire
# CORS_ALLOWED_ORIGIN_1=https://loto.arnaudwissart.fr

MAIL__ENABLED=true
MAIL__FROM=contact@EXAMPLE.TLD
MAIL__FROMNAME=Proba Loto
MAIL__BASEURL=https://loto.arnaudwissart.fr
MAIL__SMTP__HOST=smtp-relay.brevo.com
MAIL__SMTP__PORT=587
MAIL__SMTP__USESSL=true
MAIL__SMTP__USERNAME=__BREVO_SMTP_LOGIN__
MAIL__SMTP__PASSWORD=__BREVO_SMTP_KEY__
MAIL__SCHEDULE__SENDHOURLOCAL=8
MAIL__SCHEDULE__SENDMINUTELOCAL=0
MAIL__SCHEDULE__TIMEZONE=Europe/Paris
MAIL__SCHEDULE__FORCE=false
