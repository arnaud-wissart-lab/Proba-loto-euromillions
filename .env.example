# ==================================
# Proba Loto - Environment Template
# ==================================
# Copier ce fichier vers .env pour usage local uniquement.
# Ne jamais committer .env.

# Base de donnees
POSTGRES_USER=probaloto
POSTGRES_PASSWORD=change-me-strong-db-password

# Admin
ADMIN_API_KEY=change-me-strong-admin-api-key
ADMIN_WEB_USERNAME=admin
ADMIN_WEB_PASSWORD=change-me-strong-admin-password

# Liens publics + token abonnement legacy
PUBLIC_BASE_URL=https://loto.example.com
SUBSCRIPTIONS_TOKEN_SECRET=change-me-very-long-random-secret

# SMTP legacy (compose / fallback)
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=587
SMTP_USER=__SMTP_USERNAME__
SMTP_PASS=__SMTP_PASSWORD__
SMTP_FROM=Proba Loto <no-reply@example.com>
SMTP_USE_STARTTLS=true

# Mail moderne (config .NET via MAIL__*)
MAIL__ENABLED=true
MAIL__FROM=no-reply@example.com
MAIL__FROMNAME=Proba Loto
MAIL__BASEURL=https://loto.example.com
MAIL__SMTP__HOST=smtp-relay.example.com
MAIL__SMTP__PORT=587
MAIL__SMTP__USESSL=true
MAIL__SMTP__USERNAME=__SMTP_USERNAME__
MAIL__SMTP__PASSWORD=__SMTP_PASSWORD__
MAIL__SCHEDULE__SENDHOURLOCAL=8
MAIL__SCHEDULE__SENDMINUTELOCAL=0
MAIL__SCHEDULE__TIMEZONE=Europe/Paris
MAIL__SCHEDULE__FORCE=false

# Healthcheck SMTP optionnel
HEALTHCHECKS_SMTP_ENABLED=true

# CORS optionnel (origin supplementaire)
CORS_ALLOWED_ORIGIN_1=https://loto.example.com
