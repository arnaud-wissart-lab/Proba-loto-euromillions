      "TimeZoneId": "Europe/Paris",
      "RunOnStartup": true
    },
    "SendSubscriptions": {
      "Cron": "0 0/5 * * * ?",
      "TimeZoneId": "Europe/Paris",
      "RunOnStartup": true
    }
  },
  "Subscriptions": {
    "PublicBaseUrl": "http://localhost:8080"
  },
  "Mail": {
    "Enabled": true,
    "From": "no-reply@example.local",
    "FromName": "Proba Loto",
    "BaseUrl": "http://localhost:8080",
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "UseSsl": false
    },
    "Schedule": {
      "SendHourLocal": 8,
      "SendMinuteLocal": 0,
      "TimeZone": "Europe/Paris",
      "Force": false
    }
  }
