{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Jobs": {
    "SyncDraws": {
      "Cron": "0 30 2 * * ?",
      "TimeZoneId": "Europe/Paris",
      "RunOnStartup": false
    },
    "SendSubscriptions": {
      "Cron": "0 0/5 * * * ?",
      "TimeZoneId": "Europe/Paris",
      "RunOnStartup": false
    }
  },
  "DrawSync": {
    "UserAgent": "ProbabilitesLotoEuroMillions/1.0 (+https://localhost)",
    "HttpTimeoutSeconds": 30,
    "Loto": {
      "HistoryUrl": "https://www.fdj.fr/jeux-de-tirage/loto/historique",
      "RuleStartDate": "2019-11-04"
    },
    "EuroMillions": {
      "HistoryUrl": "https://www.fdj.fr/jeux-de-tirage/euromillions-my-million/historique",
      "RuleStartDate": "2016-09-01"
    }
  },
  "Subscriptions": {
    "PublicBaseUrl": "http://localhost:8080",
    "TokenSecret": "dev-only-change-me"
  },
  "Mail": {
    "Enabled": true,
    "From": "no-reply@example.local",
    "FromName": "Proba Loto",
    "BaseUrl": "http://localhost:8080",
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "UseSsl": false,
      "Username": "",
      "Password": ""
    },
    "Schedule": {
      "SendHourLocal": 8,
      "SendMinuteLocal": 0,
      "TimeZone": "Europe/Paris",
      "Force": false
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  }
}
