@page "/abonnement"
@inject LotteryApiClient LotteryApiClient
@inject ILogger<Subscription> Logger

<PageTitle>S'abonner</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="page-container">
    <MudPaper Elevation="1" Class="section-panel">
        <MudText Typo="Typo.h4" GutterBottom="true">S'abonner par e-mail</MudText>
        <MudText Typo="Typo.body2">Choisissez le nombre de grilles a recevoir pour chaque tirage.</MudText>

        <MudStack Spacing="2" Class="mt-4">
            <MudTextField Label="Adresse e-mail"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          @bind-Value="_email" />

            <MudNumericField T="int"
                             Label="Nombre de grilles Loto"
                             Variant="Variant.Outlined"
                             Min="0"
                             Max="100"
                             Immediate="true"
                             @bind-Value="_lotoGridsCount" />

            <MudNumericField T="int"
                             Label="Nombre de grilles EuroMillions"
                             Variant="Variant.Outlined"
                             Min="0"
                             Max="100"
                             Immediate="true"
                             @bind-Value="_euroMillionsGridsCount" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_isSubmitting"
                       OnClick="@SubmitAsync">
                @if (_isSubmitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                S'abonner
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mt-4">
            @_errorMessage
        </MudAlert>
    }

    @if (_submitted)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Class="mt-4">
            Si l'adresse fournie est valide, un e-mail de confirmation a ete envoye.
        </MudAlert>
    }
</MudContainer>

@code {
    private string _email = string.Empty;
    private int _lotoGridsCount = 5;
    private int _euroMillionsGridsCount = 5;
    private bool _isSubmitting;
    private bool _submitted;
    private string? _errorMessage;

    private async Task SubmitAsync()
    {
        _errorMessage = null;
        _submitted = false;

        if (!IsValidEmail(_email))
        {
            _errorMessage = "Veuillez saisir une adresse e-mail valide.";
            return;
        }

        if (_lotoGridsCount == 0 && _euroMillionsGridsCount == 0)
        {
            _errorMessage = "Choisissez au moins une grille (Loto ou EuroMillions).";
            return;
        }

        _isSubmitting = true;

        try
        {
            var success = await LotteryApiClient.RequestNewsletterSubscriptionAsync(
                new ApiNewsletterSubscribeRequest
                {
                    Email = _email,
                    LotoGridsCount = Math.Clamp(_lotoGridsCount, 0, 100),
                    EuroMillionsGridsCount = Math.Clamp(_euroMillionsGridsCount, 0, 100)
                },
                CancellationToken.None);

            if (!success)
            {
                _errorMessage = "L'abonnement n'a pas pu etre enregistre. Reessayez plus tard.";
                return;
            }

            _submitted = true;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Erreur lors de la demande d'abonnement newsletter.");
            _errorMessage = "Erreur inattendue lors de l'abonnement.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static bool IsValidEmail(string email) =>
        !string.IsNullOrWhiteSpace(email) && System.Net.Mail.MailAddress.TryCreate(email.Trim(), out _);
}
